# Asynchronous DB Connection URL (Use Supavisor pooler on port 6543 for load tests)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-DB-HOST]:6543/postgres

# Supabase Auth Settings (retrieve from Project settings -> API)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
